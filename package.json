{
  "name": "task-manager",
  "version": "2.0.0",
  "description": "팀 업무 관리 시스템",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "setup": "npm install && npm run build",
    "mail": "node scripts/sendDailyTDL.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
