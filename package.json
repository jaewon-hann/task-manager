{
  "name": "task-manager",
  "version": "1.0.0",
  "description": "개인 업무 관리 자동화 시스템",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "setup": "npm install && cd client && npm install",
    "mail": "node scripts/sendDailyTDL.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "nodemailer": "^6.9.13",
    "node-cron": "^3.0.3",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
